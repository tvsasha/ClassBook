# Скопируйте в .env на сервере и поменяйте пароль.
# SQL Server требует сложный пароль: минимум 8 символов, верхний/нижний регистр, цифры и спецсимвол.
MSSQL_SA_PASSWORD=Change_me_ClassBook_2026!

# Внешний HTTP-порт приложения на VPS. Для Caddy/Nginx обычно оставляем 8080.
CLASSBOOK_HTTP_PORT=8080

# Порт SQL Server доступен только с localhost VPS, наружу не публикуется.
CLASSBOOK_SQL_PORT=14333
CLASSBOOK_DB_NAME=ClassBookDb

# Для HTTPS через Caddy/Nginx:
CLASSBOOK_COOKIE_SAMESITE=None
CLASSBOOK_COOKIE_SECURE_POLICY=Always

# Если временно тестируете по http://IP:8080 без HTTPS, поставьте:
# CLASSBOOK_COOKIE_SAMESITE=Lax
# CLASSBOOK_COOKIE_SECURE_POLICY=SameAsRequest
